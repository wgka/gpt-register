# 复制为 .env 并按需修改（注意：`.env` 已在 `.gitignore` 中忽略，不应提交到仓库）
#
# 变量说明尽量写全，避免“只有作者自己看得懂”。

# =========================
# Telegram Bot（可选）
# =========================
# 机器人 Token（不填则不会启动 TG 机器人；强烈建议不要把真实 token 提交到仓库）
TELEGRAM_BOT_TOKEN=

# 允许使用机器人的 chat_id 白名单（逗号分隔；不填则允许所有 chat 使用，风险很大）
# 示例：TELEGRAM_ALLOWED_CHAT_IDS=123456789,987654321
TELEGRAM_ALLOWED_CHAT_IDS=

# Telegram SDK 调试日志开关：true/false
TELEGRAM_DEBUG=false

# =========================
# CPA（可选）
# =========================
# CPA API 地址（你的 CPA 服务端 URL）
APP_CPA_API_URL=

# CPA API Token（鉴权 token）
APP_CPA_API_TOKEN=

# 是否启用自动上传 CPA：true/false
APP_CPA_ENABLED=false

# =========================
# 线上账号定时维护（可选）
# =========================
# 是否启用线上账号定时任务：true/false
APP_ONLINE_ACCOUNTS_SCHEDULE_ENABLED=false

# 调度模式：interval / fixed_times
APP_ONLINE_ACCOUNTS_SCHEDULE_MODE=interval

# 定时任务执行周期（分钟）
APP_ONLINE_ACCOUNTS_SCHEDULE_INTERVAL_MINUTES=30

# 固定执行时间，多个时间用英文逗号分隔（24 小时制）
# 示例：09:00,14:30,23:00
APP_ONLINE_ACCOUNTS_SCHEDULE_FIXED_TIMES=09:00

# 定时禁用 Token 失效账号：已弃用，固定为 false
APP_ONLINE_ACCOUNTS_SCHEDULE_DISABLE_TOKEN_INVALID=false

# 定时删除 Token 失效账号：true/false
APP_ONLINE_ACCOUNTS_SCHEDULE_DELETE_TOKEN_INVALID=true

# 失败自动重试次数（0 表示不重试）
APP_ONLINE_ACCOUNTS_SCHEDULE_RETRY_COUNT=2

# 失败后重试延迟（分钟）
APP_ONLINE_ACCOUNTS_SCHEDULE_RETRY_DELAY_MINUTES=5

# 读取线上账号列表超时（秒）；账号量大时可适当调大
APP_ONLINE_ACCOUNTS_LIST_TIMEOUT_SECONDS=120

# 禁用/删除线上账号请求超时（秒）
APP_ONLINE_ACCOUNTS_MUTATION_TIMEOUT_SECONDS=60

# =========================
# 代理来源（可选）
# =========================
# 授权模式（注册/登录主链路）：
# - chatgpt_web：沿用 ChatGPT Web 登录链路
# - codex_cli：使用 Codex/CLI 风格 OAuth 参数（PKCE + localhost callback）
APP_AUTH_MODE=chatgpt_web

# 当 APP_AUTH_MODE=codex_cli 时，以下 OAuth 参数会生效；
# 留空则使用程序内置默认值。
# APP_OPENAI_CLIENT_ID=app_EMoamEEZ73f0CkXaXp7hrann
# APP_OPENAI_AUTH_URL=https://auth.openai.com/oauth/authorize
# APP_OPENAI_TOKEN_URL=https://auth.openai.com/oauth/token
# APP_OPENAI_REDIRECT_URI=http://localhost:1455/auth/callback
# APP_OPENAI_SCOPE=openid email profile offline_access

# 动态代理 API 地址（返回代理池 JSON；不要把本地 Clash/固定代理地址填到这里）
APP_PROXY_API_URL=

# 动态代理最大尝试次数；Socks5 节点质量不稳时可适当提高
APP_PROXY_ATTEMPTS=4

# 单个动态代理预检超时（秒）；建议 Socks5 场景控制在 8-15 秒
APP_PROXY_PREFLIGHT_TIMEOUT=12

# 固定代理地址（本地 Clash、稳定海外 HTTP/SOCKS5 代理填这里）
# 示例：
# APP_PROXY_URL=http://127.0.0.1:7897
# APP_PROXY_URL=socks5://127.0.0.1:7890
APP_PROXY_URL=

# =========================
# 临时邮箱 API（注册默认使用）
# =========================
# 临时邮箱服务基地址；默认是 http://82.158.91.228:8081
TEMP_MAIL_API_BASE_URL=http://82.158.91.228:8081
