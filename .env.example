# 复制为 .env 并按需修改（注意：`.env` 已在 `.gitignore` 中忽略，不应提交到仓库）
#
# 变量说明尽量写全，避免“只有作者自己看得懂”。

# =========================
# Telegram Bot（可选）
# =========================
# 机器人 Token（不填则不会启动 TG 机器人；强烈建议不要把真实 token 提交到仓库）
TELEGRAM_BOT_TOKEN=

# 允许使用机器人的 chat_id 白名单（逗号分隔；不填则允许所有 chat 使用，风险很大）
# 示例：TELEGRAM_ALLOWED_CHAT_IDS=123456789,987654321
TELEGRAM_ALLOWED_CHAT_IDS=

# Telegram SDK 调试日志开关：true/false
TELEGRAM_DEBUG=false

# =========================
# CPA（可选）
# =========================
# CPA API 地址（你的 CPA 服务端 URL）
APP_CPA_API_URL=

# CPA API Token（鉴权 token）
APP_CPA_API_TOKEN=

# 是否启用自动上传 CPA：true/false
APP_CPA_ENABLED=false

# =========================
# 代理来源（可选）
# =========================
# 代理 API 地址（用于获取代理；留空则按运行时/配置策略自行决定）
APP_PROXY_API_URL=
